{
    "name": "mailgun-to-ses-proxy",
    "version": "2.0.17",
    "private": true,
    "scripts": {
        "dev": "nodemon",
        "next:build": "next build --webpack",
        "docker:build": "docker build -t mailgun-to-ses-proxy .",
        "build": "prisma generate && next build --webpack && tsc --project tsconfig.server.json",
        "start": "NODE_ENV=production prisma migrate deploy && node dist/server.js",
        "start:bun": "NODE_ENV=production prisma migrate deploy && bun dist/server.js",
        "lint": "next lint",
        "db:migrate:dev": "prisma migrate dev",
        "db:migrate": "prisma migrate deploy",
        "db:generate": "prisma generate",
        "test": "runPrismaTests=false vitest",
        "test:prisma": "vitest --run tests/prisma-orm.test.ts",
        "test:run": "runPrismaTests=false vitest --run",
        "test:coverage": "vitest --coverage",
        "test:watch": "vitest --watch",
        "test:ui": "vitest --ui",
        "bump": "npm version patch && git push --tags"
    },
    "dependencies": {
        "@aws-sdk/client-sesv2": "^3.914.0",
        "@aws-sdk/client-sqs": "^3.914.0",
        "@prisma/adapter-mariadb": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "dotenv": "^17.3.1",
        "mariadb": "^3.5.2",
        "next": "^16.0.7",
        "pino": "^10.1.0",
        "prisma": "^7.5.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.16",
        "@types/node": "^24.9.1",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "nodemon": "^3.1.9",
        "pino-pretty": "^13.1.2",
        "tailwindcss": "^4.1.16",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "vitest": "^4.0.1"
    }
}
